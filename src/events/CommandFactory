/* ==========================================================
   SCIIP_OS
   Module: Events
   File: CommandFactory.gs

   Purpose:
   Creates canonical SCIIP commands.

   Commands represent requested actions.

   Commands produce Events.

   Observation
        ↓
   Command
        ↓
   Event
        ↓
   Graph
        ↓
   Timeline

   Vocabulary is governed by:

   SCIIP.VOCABULARY.COMMAND_TYPES
   SCIIP.VOCABULARY.EVENT_TYPES

   Source of Truth:
   GitHub

   Runtime:
   Google Apps Script
========================================================== */

/**
 * Creates a command.
 *
 * @param {string} commandType
 * @param {Object} payload
 * @returns {Object}
 */
function sciipCreateCommand(
  commandType,
  payload
) {

  sciipValidateCommandType(
    commandType
  );

  const data =
    payload || {};

  return {

    commandId:
      'COMMAND_' +
      sciipUuid()
        .replace(/-/g, '')
        .substring(0, 16)
        .toUpperCase(),

    commandType:
      commandType,

    payload:
      data,

    createdAt:
      sciipNowIso()
  };
}

/**
 * Validates command type.
 *
 * Uses centralized vocabulary registry.
 *
 * @param {string} commandType
 */
function sciipValidateCommandType(
  commandType
) {

  if (
    !Object.values(
      SCIIP.VOCABULARY.COMMAND_TYPES
    ).includes(commandType)
  ) {

    throw new Error(
      'Invalid Command Type: ' +
      commandType
    );
  }
}

/**
 * Converts a command into an event.
 *
 * Initial implementation.
 *
 * Future:
 * - Command Handlers
 * - Validation Pipelines
 * - Work Queues
 * - Retry Logic
 *
 * @param {Object} command
 * @returns {Object}
 */
function sciipExecuteCommand(
  command
) {

  switch (
    command.commandType
  ) {

    case SCIIP.VOCABULARY.COMMAND_TYPES.CREATE_ASSET:

      return sciipCreateAndRecordEvent(
        SCIIP.VOCABULARY.EVENT_TYPES.ASSET_CREATED,
        command.payload
      );

    case SCIIP.VOCABULARY.COMMAND_TYPES.CREATE_CANDIDATE:

      return sciipCreateAndRecordEvent(
        SCIIP.VOCABULARY.EVENT_TYPES.CANDIDATE_CREATED,
        command.payload
      );

    case SCIIP.VOCABULARY.COMMAND_TYPES.CREATE_ALIAS:

      return sciipCreateAndRecordEvent(
        SCIIP.VOCABULARY.EVENT_TYPES.ALIAS_CREATED,
        command.payload
      );

    case SCIIP.VOCABULARY.COMMAND_TYPES.CREATE_GRAPH_NODE:

      return sciipCreateAndRecordEvent(
        SCIIP.VOCABULARY.EVENT_TYPES.GRAPH_NODE_CREATED,
        command.payload
      );

    case SCIIP.VOCABULARY.COMMAND_TYPES.CREATE_GRAPH_EDGE:

      return sciipCreateAndRecordEvent(
        SCIIP.VOCABULARY.EVENT_TYPES.GRAPH_EDGE_CREATED,
        command.payload
      );

    case SCIIP.VOCABULARY.COMMAND_TYPES.RECORD_OBSERVATION:

      return sciipCreateAndRecordEvent(
        SCIIP.VOCABULARY.EVENT_TYPES.PROPERTY_OBSERVED,
        command.payload
      );

    default:

      throw new Error(
        'Unhandled Command Type: ' +
        command.commandType
      );
  }
}

/**
 * Creates and executes a command.
 *
 * @param {string} commandType
 * @param {Object} payload
 * @returns {Object}
 */
function sciipCreateAndExecuteCommand(
  commandType,
  payload
) {

  const command =
    sciipCreateCommand(
      commandType,
      payload
    );

  return sciipExecuteCommand(
    command
  );
}

/**
 * Returns all command types.
 *
 * @returns {Object}
 */
function sciipGetCommandTypes() {

  return SCIIP.VOCABULARY.COMMAND_TYPES;
}

/**
 * Returns command factory statistics.
 *
 * @returns {Object}
 */
function sciipCommandFactoryStats() {

  return {

    commandTypes:
      Object.keys(
        SCIIP.VOCABULARY.COMMAND_TYPES
      ).length,

    generatedAt:
      sciipNowIso()
  };
}