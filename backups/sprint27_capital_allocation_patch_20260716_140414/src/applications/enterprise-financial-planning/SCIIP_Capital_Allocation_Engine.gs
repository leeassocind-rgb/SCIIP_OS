var SCIIP_CAPITAL_ALLOCATION_ENGINE=(function(){'use strict';function allocate(input){var budget=Number(input&&input.budget||0),requests=((input&&input.requests)||[]).slice().sort(function(a,b){return Number(b.returnScore||0)-Number(a.returnScore||0);}),used=0,selected=[];requests.forEach(function(r){var c=Number(r.amount||0);if(used+c<=budget){selected.push(r);used+=c;}});return {status:'ALLOCATED',budget:budget,allocated:used,remaining:budget-used,selected:selected};}return {allocate:allocate};})();
